# ────────────────────────────────────────────────────────
# GEOINT Dashboard — Environment Configuration
# Copy to .env and fill in actual values
# Classification: UNCLASSIFIED (config template only)
# ────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ── PostgreSQL + PostGIS ────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=geoint_dashboard
PGUSER=geoint_admin
PGPASSWORD=CHANGE_ME_IN_PRODUCTION
PGSSL=false
PG_POOL_MIN=2
PG_POOL_MAX=20

# ── JWT Authentication ──────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── WebSocket ───────────────────────────────────────────
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_PAYLOAD_BYTES=65536

# ── Geofence Worker ────────────────────────────────────
GEOFENCE_CHECK_INTERVAL_MS=2000
GEOFENCE_ALERT_COOLDOWN_MS=60000

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
